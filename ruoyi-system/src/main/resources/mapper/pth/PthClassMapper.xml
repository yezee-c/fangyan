<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.pth.mapper.PthClassMapper">
    
    <resultMap type="PthClass" id="PthClassResult">
        <result property="classId"    column="class_id"    />
        <result property="className"    column="class_name"    />
        <result property="grade"    column="grade"    />
        <result property="semester"    column="semester"    />
        <result property="invitationCode"    column="invitation_code"    />
        <result property="teacherId"    column="teacher_id"    />
        <result property="teacherName"    column="teacher_name"    />
        <result property="studentCount"    column="student_count"    />
        <result property="status"    column="status"    />
        <result property="delFlag"    column="del_flag"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
        <result property="remark"    column="remark"    />
    </resultMap>

    <sql id="selectPthClassVo">
        select class_id, class_name, grade, semester, invitation_code, teacher_id, teacher_name, student_count, status, del_flag, create_by, create_time, update_by, update_time, remark from pth_class
    </sql>

    <select id="selectPthClassList" parameterType="PthClass" resultMap="PthClassResult">
        <include refid="selectPthClassVo"/>
        <where>  
            <if test="className != null  and className != ''"> and class_name like concat('%', #{className}, '%')</if>
            <if test="grade != null  and grade != ''"> and grade = #{grade}</if>
            <if test="semester != null  and semester != ''"> and semester = #{semester}</if>
            <if test="invitationCode != null  and invitationCode != ''"> and invitation_code = #{invitationCode}</if>
            <if test="teacherId != null "> and teacher_id = #{teacherId}</if>
            <if test="status != null  and status != ''"> and status = #{status}</if>
            and del_flag = '0'
        </where>
        order by create_time desc
    </select>
    
    <select id="selectPthClassByClassId" parameterType="Long" resultMap="PthClassResult">
        <include refid="selectPthClassVo"/>
        where class_id = #{classId}
    </select>

    <select id="selectPthClassListByTeacherId" parameterType="Long" resultMap="PthClassResult">
        <include refid="selectPthClassVo"/>
        where teacher_id = #{teacherId} and del_flag = '0' and status = '0'
        order by create_time desc
    </select>

    <select id="selectPthClassByInvitationCode" parameterType="String" resultMap="PthClassResult">
        <include refid="selectPthClassVo"/>
        where invitation_code = #{invitationCode} and del_flag = '0'
    </select>

    <select id="checkInvitationCodeUnique" parameterType="String" resultType="int">
        select count(1) from pth_class where invitation_code = #{invitationCode} and del_flag = '0'
    </select>

    <insert id="insertPthClass" parameterType="PthClass" useGeneratedKeys="true" keyProperty="classId">
        insert into pth_class
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="className != null and className != ''">class_name,</if>
            <if test="grade != null">grade,</if>
            <if test="semester != null">semester,</if>
            <if test="invitationCode != null and invitationCode != ''">invitation_code,</if>
            <if test="teacherId != null">teacher_id,</if>
            <if test="teacherName != null">teacher_name,</if>
            <if test="studentCount != null">student_count,</if>
            <if test="status != null">status,</if>
            <if test="delFlag != null">del_flag,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="remark != null">remark,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="className != null and className != ''">#{className},</if>
            <if test="grade != null">#{grade},</if>
            <if test="semester != null">#{semester},</if>
            <if test="invitationCode != null and invitationCode != ''">#{invitationCode},</if>
            <if test="teacherId != null">#{teacherId},</if>
            <if test="teacherName != null">#{teacherName},</if>
            <if test="studentCount != null">#{studentCount},</if>
            <if test="status != null">#{status},</if>
            <if test="delFlag != null">#{delFlag},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="remark != null">#{remark},</if>
         </trim>
    </insert>

    <update id="updatePthClass" parameterType="PthClass">
        update pth_class
        <trim prefix="SET" suffixOverrides=",">
            <if test="className != null and className != ''">class_name = #{className},</if>
            <if test="grade != null">grade = #{grade},</if>
            <if test="semester != null">semester = #{semester},</if>
            <if test="invitationCode != null and invitationCode != ''">invitation_code = #{invitationCode},</if>
            <if test="teacherId != null">teacher_id = #{teacherId},</if>
            <if test="teacherName != null">teacher_name = #{teacherName},</if>
            <if test="studentCount != null">student_count = #{studentCount},</if>
            <if test="status != null">status = #{status},</if>
            <if test="delFlag != null">del_flag = #{delFlag},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
        </trim>
        where class_id = #{classId}
    </update>

    <update id="updateStudentCount">
        update pth_class set student_count = #{count} where class_id = #{classId}
    </update>

    <delete id="deletePthClassByClassId" parameterType="Long">
        update pth_class set del_flag = '2' where class_id = #{classId}
    </delete>

    <delete id="deletePthClassByClassIds" parameterType="String">
        update pth_class set del_flag = '2' where class_id in 
        <foreach item="classId" collection="array" open="(" separator="," close=")">
            #{classId}
        </foreach>
    </delete>
</mapper>
